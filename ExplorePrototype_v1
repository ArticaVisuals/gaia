}

export default function GaiaBottomSheet() {
  const [state, setState] = useState(1);
  const sheetY = useMotionValue(SCREEN_H * SNAPS[1]);
  const dragStartY = useRef(0);
  const dragStartSheetY = useRef(0);
  const isDragging = useRef(false);

  const sheetBorderRadius = useTransform(sheetY, [SCREEN_H * 0.05, SCREEN_H * 0.18], [0, 28]);
  const state1LabelOpacity = useTransform(sheetY, [SCREEN_H * 0.74, SCREEN_H * 0.80], [0, 1]);
  const contentOpacity = useTransform(sheetY, [SCREEN_H * 0.56, SCREEN_H * 0.68], [1, 0]);
  const findsOpacity = useTransform(sheetY, [SCREEN_H * 0.14, SCREEN_H * 0.28], [1, 0]);

  function snapTo(targetState) {
    setState(targetState);
    animate(sheetY, SCREEN_H * SNAPS[targetState], { type: "spring", stiffness: 400, damping: 42, mass: 0.75 });
  }

  function onPointerDown(e) {
    isDragging.current = true;
    dragStartY.current = e.clientY;
    dragStartSheetY.current = sheetY.get();
    e.currentTarget.setPointerCapture(e.pointerId);
  }

  function onPointerMove(e) {
    if (!isDragging.current) return;
    const delta = e.clientY - dragStartY.current;
    const newY = Math.max(SCREEN_H * 0.07, Math.min(SCREEN_H * 0.88, dragStartSheetY.current + delta));
    sheetY.set(newY);
  }

  function onPointerUp(e) {
    if (!isDragging.current) return;
    isDragging.current = false;
    const totalDelta = e.clientY - dragStartY.current;
    const currentY = sheetY.get();
    const velocity = totalDelta / 120;
    let target;
    if (velocity > 0.5) target = Math.min(state + 1, 3);
    else if (velocity < -0.5) target = Math.max(state - 1, 1);
    else target = Object.entries(SNAPS).sort((a, b) => Math.abs(currentY - SCREEN_H * a[1]) - Math.abs(currentY - SCREEN_H * b[1]))[0][0];
    snapTo(Number(target));
  }

  const scale = 0.72;

  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", minHeight: "100vh", background: "linear-gradient(160deg, #1a1f18 0%, #111410 100%)", padding: 24, gap: 24, fontFamily: "system-ui" }}>
      {/* Phone shell */}
      <div style={{ width: SCREEN_W * scale, height: SCREEN_H * scale, borderRadius: 44 * scale, overflow: "hidden", position: "relative", boxShadow: "0 40px 100px rgba(0,0,0,0.75), 0 0 0 1px rgba(255,255,255,0.07)", flexShrink: 0 }}>
        <div style={{ width: SCREEN_W, height: SCREEN_H, transform: `scale(${scale})`, transformOrigin: "top left", position: "relative", overflow: "hidden", background: C.mapLand }}>
          {/* Status bar */}
          <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 44, zIndex: 25, display: "flex", alignItems: "center", justifyContent: "space-between", padding: "0 28px" }}>
            <span style={{ fontSize: 13, fontWeight: 700, color: C.inkBlack }}>9:41</span>
            <span style={{ fontSize: 10, color: C.inkBlack, opacity: 0.5 }}>●●● 🔋</span>
          </div>

          <MapBackground />
          <MapControls sheetY={sheetY} />
          <TopBar />

          {/* Bottom Sheet */}
          <motion.div
            style={{ position: "absolute", left: 0, right: 0, top: 0, height: SCREEN_H * 2, y: sheetY, borderTopLeftRadius: sheetBorderRadius, borderTopRightRadius: sheetBorderRadius, background: C.paperWhite, boxShadow: "0 -6px 48px rgba(94,98,98,0.16)", zIndex: 15, cursor: "grab", userSelect: "none" }}
            onPointerDown={onPointerDown}
            onPointerMove={onPointerMove}
            onPointerUp={onPointerUp}
          >
            {/* Handle */}
            <div style={{ width: 44, height: 4, borderRadius: 2, background: "rgba(94,98,98,0.25)", margin: "12px auto 0" }} />

            {/* State 1 label */}
            <motion.div style={{ position: "absolute", top: 24, left: 0, right: 0, display: "flex", justifyContent: "center", opacity: state1LabelOpacity, pointerEvents: "none" }}>
              <span style={{ fontSize: 14, fontWeight: 500, color: C.blackishGrey }}>3 nearby projects</span>
            </motion.div>

            {/* States 2+3 content */}
            <motion.div style={{ opacity: contentOpacity }}>
              <div style={{ padding: "20px 20px 16px" }}>
                <span style={{ fontFamily: "Georgia, serif", fontSize: 34, fontWeight: 600, color: C.oliveGreen, lineHeight: 1 }}>Nearby</span>
              </div>
              <div style={{ display: "flex", gap: 8, padding: "0 20px 18px", overflow: "hidden" }}>
                {["Nearby", "Needs ID", "Projects", "Friends"].map((chip, i) => (
                  <div key={chip} style={{ flexShrink: 0, padding: "6px 14px", borderRadius: 20, background: i === 0 ? C.asparagus : "rgba(94,98,98,0.08)", border: `0.5px solid ${i === 0 ? C.oliveGreen : "rgba(94,98,98,0.18)"}`, fontSize: 12, color: i === 0 ? C.oliveGreen : C.blackishGrey, fontWeight: i === 0 ? 600 : 400 }}>{chip}</div>
                ))}
              </div>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "0 20px 12px" }}>
                <span style={{ fontSize: 17, fontWeight: 500, color: C.inkBlack }}>Projects</span>
                <span style={{ fontSize: 12, color: C.oliveGreen }}>See all</span>
              </div>
              <div style={{ display: "flex", gap: 10, padding: "0 20px", overflow: "hidden" }}>
                {[
                  { tag: "Wildflowers", name: "Pollinator Corridor", count: "24 Observers", bg: C.mapTerrain },
                  { tag: "Wetland", name: "Creek Recovery", count: "12 Observers", bg: "#D4CEB8" },
                  { tag: "Wildflowers", name: "Pollinator Corridor", count: "24 Observers", bg: "#CECA9E" },
                ].map((p, i) => (
                  <div key={i} style={{ flexShrink: 0, width: 158, height: 124, borderRadius: 14, background: p.bg, padding: 12, display: "flex", flexDirection: "column", justifyContent: "space-between" }}>
                    <div style={{ display: "inline-flex", padding: "2px 10px", borderRadius: 10, background: "rgba(252,250,240,0.85)", alignSelf: "flex-start", fontSize: 10, color: C.blackishGrey }}>{p.tag}</div>
                    <div>
                      <div style={{ fontSize: 13, color: C.inkBlack, fontWeight: 500, marginBottom: 2 }}>{p.name}</div>
                      <div style={{ fontSize: 10, color: C.blackishGrey, opacity: 0.65 }}>{p.count}</div>
                    </div>
                  </div>
                ))}
              </div>

              {/* Finds — State 3 */}
              <motion.div style={{ opacity: findsOpacity, marginTop: 20 }}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "0 20px 12px" }}>
                  <span style={{ fontSize: 17, fontWeight: 500, color: C.inkBlack }}>Finds</span>
                  <div style={{ display: "flex", gap: 4 }}>
                    {[true, false].map((active, i) => (
                      <div key={i} style={{ width: 30, height: 30, borderRadius: 8, background: active ? C.asparagus : "rgba(94,98,98,0.08)", border: `0.5px solid ${active ? C.oliveGreen : "rgba(94,98,98,0.18)"}`, display: "flex", alignItems: "center", justifyContent: "center" }}>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke={active ? C.oliveGreen : C.blackishGrey} strokeWidth="2">
                          {i === 0 ? <><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></> : <><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/></>}
                        </svg>
                      </div>
                    ))}
                  </div>
                </div>
                <div style={{ padding: "0 20px", display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 8 }}>
                  {Array.from({ length: 6 }).map((_, i) => (
                    <div key={i} style={{ aspectRatio: "1", borderRadius: 10, background: [C.mapTerrain, "#D9D4C4", "#E0DECE", "#D4CEB8", C.mapTerrain, "#CECA9E"][i] }} />
                  ))}
                </div>
              </motion.div>
            </motion.div>
          </motion.div>

          <NavBar />
        </div>
      </div>

      {/* Controls */}
      <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 10 }}>
        <div style={{ display: "flex", gap: 8 }}>
          {[1, 2, 3].map(s => (
            <button key={s} onClick={() => snapTo(s)} style={{ width: 90, height: 38, borderRadius: 19, background: state === s ? C.oliveGreen : "rgba(255,255,255,0.07)", border: `1px solid ${state === s ? C.oliveGreen : "rgba(255,255,255,0.15)"}`, color: state === s ? "white" : "rgba(255,255,255,0.4)", fontSize: 12, fontWeight: 600, cursor: "pointer", transition: "all 0.18s ease", letterSpacing: 0.3 }}>
              State {s}
            </button>
          ))}
        </div>
        <p style={{ color: "rgba(255,255,255,0.25)", fontSize: 11, margin: 0, letterSpacing: 0.3 }}>
          Drag the sheet · or tap a state
        </p>
      </div>
    </div>
  );
}
