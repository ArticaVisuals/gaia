    }}>
      <div style={{ width: 42, height: 42, borderRadius: 21, background: "rgba(252,250,240,0.96)", border: "0.5px solid rgba(94,98,98,0.15)", boxShadow: "0 2px 14px rgba(94,98,98,0.14)", display: "flex", alignItems: "center", justifyContent: "center" }}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={C.blackishGrey} strokeWidth="2" opacity="0.7"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
      </div>
      <div style={{ height: 42, borderRadius: 22, background: "rgba(252,250,240,0.96)", border: "0.5px solid rgba(94,98,98,0.15)", boxShadow: "0 2px 14px rgba(94,98,98,0.14)", display: "flex", alignItems: "center", gap: 2, padding: "4px 6px" }}>
        {[true, false, false].map((active, j) => (
          <div key={j} style={{ width: 36, height: 32, borderRadius: 16, background: active ? C.oliveGreen : "transparent", display: "flex", alignItems: "center", justifyContent: "center" }}>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke={active ? "white" : C.blackishGrey} strokeWidth="1.8" opacity={active ? 1 : 0.6}>
              {j === 0 && <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>}
              {j === 1 && <><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></>}
              {j === 2 && <><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/></>}
