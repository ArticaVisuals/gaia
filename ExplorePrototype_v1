    <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, zIndex: 30, padding: "8px 20px 22px" }}>
      <div style={{ background: "rgba(252,250,240,0.94)", backdropFilter: "blur(16px)", border: "0.5px solid rgba(252,250,240,0.7)", borderRadius: 44, padding: "8px 12px", display: "flex", alignItems: "center", justifyContent: "space-around", boxShadow: "0 4px 28px rgba(94,98,98,0.12)" }}>
        {[{ label: "Explore", active: true }, { label: "Observe", active: false }, { label: "Profile", active: false }].map(({ label, active }) => (
          <div key={label} style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 3, padding: "6px 22px", borderRadius: 30, background: active ? `${C.oliveGreen}20` : "transparent", minWidth: 72 }}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={active ? C.oliveGreen : C.blackishGrey} strokeWidth={active ? "1.8" : "1.4"} opacity={active ? 1 : 0.45}>
              {label === "Explore" && <><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></>}
              {label === "Observe" && <><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></>}
